<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.OfferController" stylesheets="@../../../style.css" styleClass="root">
   <top>
      <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
         <padding>
            <Insets top="10" right="20" bottom="10" left="20"/>
         </padding>
         <children>
            <Button text="Back" onAction="#handleBack" styleClass="button, secondary-button"/>
            <Label text="Offer Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </top>
   <center>
      <VBox spacing="20">
         <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
         </padding>
         <children>
            <GridPane fx:id="adminForm" hgap="10" vgap="10" styleClass="card">
               <padding>
                  <Insets top="15" right="15" bottom="15" left="15"/>
               </padding>
               <children>
                  <Label text="Prop ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                  <TextField fx:id="propertyIdField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                  
                  <Label text="Title:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                  <TextField fx:id="titleField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                  
                  <Label text="Discount %:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                  <TextField fx:id="discountField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                  
                  <Label text="Start Date:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                  <DatePicker fx:id="startDatePicker" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                  
                  <Label text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                  <DatePicker fx:id="endDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                  <Label text="Description:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                  <TextField fx:id="descriptionField" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                  
                  <CheckBox fx:id="isActiveCheck" text="Is Active" selected="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                  
                  <HBox spacing="10" GridPane.columnIndex="3" GridPane.rowIndex="3" alignment="CENTER_RIGHT">
                     <children>
                        <Button text="Clear" onAction="#handleClearForm" styleClass="button"/>
                        <Button text="Add" onAction="#handleAddOffer" styleClass="button, primary-button"/>
                        <Button text="Update" onAction="#handleUpdateOffer" styleClass="button, secondary-button"/>
                        <Button text="Delete" onAction="#handleDeleteOffer" styleClass="button, danger-button"/>
                     </children>
                  </HBox>
               </children>
            </GridPane>
            
            <TableView fx:id="offerTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                  <TableColumn fx:id="propertyIdCol" text="Prop ID" prefWidth="60"/>
                  <TableColumn fx:id="titleCol" text="Title" prefWidth="120"/>
                  <TableColumn fx:id="descriptionCol" text="Description" prefWidth="120"/>
                  <TableColumn fx:id="discountCol" text="Discount %" prefWidth="80"/>
                  <TableColumn fx:id="startDateCol" text="Start" prefWidth="100"/>
                  <TableColumn fx:id="endDateCol" text="End" prefWidth="100"/>
                  <TableColumn fx:id="isActiveCol" text="Active" prefWidth="60"/>
                  <TableColumn fx:id="createdAtCol" text="Created At" prefWidth="120"/>
                  <TableColumn fx:id="actionsCol" text="Actions" prefWidth="100"/>
               </columns>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>
