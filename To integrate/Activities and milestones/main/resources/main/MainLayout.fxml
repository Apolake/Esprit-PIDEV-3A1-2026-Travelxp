<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travelxp.controllers.MainLayoutController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="240" styleClass="sidebar">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand-box">
                <Label text="TravelXP" styleClass="sidebar-brand-name"/>
                <Label text="TRIPS • ACTIVITIES • MILESTONES" styleClass="sidebar-brand-tagline"/>
            </VBox>

            <!-- Section -->
            <Label text="MODULES" styleClass="sidebar-section-label"/>

            <Button fx:id="btnTrips"
                    text="Trips"
                    onAction="#openTrips"
                    styleClass="sidebar-nav-btn"/>

            <Button fx:id="btnActivities"
                    text="Activities"
                    onAction="#openActivities"
                    styleClass="sidebar-nav-btn"/>

            <Button fx:id="btnMilestones"
                    text="Milestones"
                    onAction="#openMilestones"
                    styleClass="sidebar-nav-btn"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Footer -->
            <HBox styleClass="sidebar-footer">
                <Label text="JavaFX 17 • TravelXP" styleClass="sidebar-footer-text"/>
            </HBox>

            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>
        </VBox>
    </left>

    <!-- MAIN CONTENT HOLDER -->
    <center>
        <!-- ✅ سنحقن الصفحات هنا -->
        <StackPane fx:id="contentHolder" styleClass="content-area"/>
    </center>

</BorderPane>