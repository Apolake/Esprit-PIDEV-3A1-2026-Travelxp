<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travelxp.controllers.TripMilestoneFormController"
            styleClass="content-area">

    <top>
        <VBox spacing="6" styleClass="page-header">
            <Label fx:id="formTitle" text="Add Milestone" styleClass="page-title"/>
            <Label text="Fill the form then click Save." styleClass="page-subtitle"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
            <content>
                <VBox spacing="14" styleClass="card">

                    <Label fx:id="errorLabel" styleClass="error-label error-label-hidden"/>

                    <Label text="BASIC INFO" styleClass="section-title"/>

                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="26"/>
                            <ColumnConstraints percentWidth="74"/>
                        </columnConstraints>

                        <Label text="Trip *" styleClass="form-label"
                               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="tripCombo"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Title *" styleClass="form-label"
                               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="titleField" promptText="Required"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Description" styleClass="form-label"
                               GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextArea fx:id="descriptionArea" prefRowCount="3"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Milestone Date *" styleClass="form-label"
                               GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="milestoneDatePicker"
                                    GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Status" styleClass="form-label"
                               GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="statusCombo"
                                  GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="XP Earned" styleClass="form-label"
                               GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <TextField fx:id="xpField" promptText="e.g. 10"
                                   GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                    </GridPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="toolbar-bar">
            <Button text="Cancel" onAction="#cancel" styleClass="btn-secondary"/>
            <Button text="Save" onAction="#save" styleClass="btn-primary"/>
        </HBox>
    </bottom>

    <padding>
        <Insets top="16" right="18" bottom="18" left="18"/>
    </padding>

</BorderPane>