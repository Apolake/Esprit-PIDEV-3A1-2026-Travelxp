<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Pane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.EditProfileController" styleClass="root">
   <children>
      <Pane fx:id="animatedBg" styleClass="animated-bg" />
      <VBox alignment="CENTER" maxWidth="550.0" spacing="35.0" styleClass="card, glass-card">
         <children>
            <VBox spacing="10">
               <children>
                  <Label text="Edit Your Profile" styleClass="title-1" />
                  <Label text="Keep your journey details up to date." styleClass="text-muted" />
               </children>
            </VBox>
            
            <VBox spacing="20.0">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="New Email Address" styleClass="text-caption" />
                        <TextField fx:id="emailField" promptText="Enter new email" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Date of Birth" styleClass="text-caption" />
                        <DatePicker fx:id="birthdayPicker" maxWidth="Infinity" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Profile Bio" styleClass="text-caption" />
                        <TextArea fx:id="bioArea" prefHeight="120.0" promptText="Update your bio..." />
                     </children>
                  </VBox>
                  <HBox spacing="15.0" alignment="CENTER_LEFT">
                     <children>
                        <Button onAction="#handleImageUpload" styleClass="flat" text="Change Profile Image" />
                        <Label fx:id="imagePathLabel" text="No image selected" styleClass="text-muted" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <HBox spacing="20.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleUpdate" text="Save Changes" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="accent" />
                  <Button onAction="#handleCancel" styleClass="flat" text="Cancel" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
      </VBox>
      <Button onAction="#toggleTheme" styleClass="theme-toggle-button" StackPane.alignment="TOP_RIGHT">
         <graphic>
            <Region styleClass="theme-icon" />
         </graphic>
         <StackPane.margin>
            <Insets top="20" right="20" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>
