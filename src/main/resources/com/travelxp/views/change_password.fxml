<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Pane?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.travelxp.controllers.ChangePasswordController" styleClass="root">
   <children>
      <Pane fx:id="animatedBg" styleClass="animated-bg" />
      <VBox alignment="CENTER" maxWidth="450.0" spacing="35.0" styleClass="card, glass-card">
         <children>
            <VBox spacing="10">
               <children>
                  <Label text="Change Password" styleClass="title-1" />
                  <Label text="Update your account security." styleClass="text-muted" />
               </children>
            </VBox>
            
            <VBox spacing="20.0">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Current Password" styleClass="text-caption" />
                        <PasswordField fx:id="currentPasswordField" promptText="Enter current password" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="New Password" styleClass="text-caption" />
                        <PasswordField fx:id="newPasswordField" promptText="8+ chars, 1 letter, 1 number" />
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="Confirm New Password" styleClass="text-caption" />
                        <PasswordField fx:id="confirmNewPasswordField" promptText="Repeat new password" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            
            <HBox spacing="20.0" alignment="CENTER">
               <children>
                  <Button onAction="#handleChangePassword" text="Save Changes" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="accent" />
                  <Button onAction="#handleCancel" styleClass="flat" text="Cancel" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
      </VBox>
      <Button onAction="#toggleTheme" styleClass="theme-toggle-button" StackPane.alignment="TOP_RIGHT">
         <graphic>
            <Region styleClass="theme-icon" />
         </graphic>
         <StackPane.margin>
            <Insets top="20" right="20" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>
